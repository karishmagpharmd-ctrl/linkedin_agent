{
  "name": "linkedin-auto-poster",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "post": "node --env-file-if-exists=.env scripts/generate-and-post.mjs",
