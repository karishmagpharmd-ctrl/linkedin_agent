# Google Gemini API Config
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# LinkedIn API Config
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_ID=

# LinkedIn OAuth App Credentials (for minting tokens locally)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Auto Poster Behavior
POST_TOPICS=
INCLUDE_BANNER=true
BANNER_BRAND=Your Name
DRY_RUN=false
